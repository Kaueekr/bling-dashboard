# ═══════════════════════════════════════════════════
# BLING DASHBOARD - Variáveis de Ambiente
# ═══════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores

# Credenciais do aplicativo Bling (obrigatório)
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=seu_client_secret_aqui

# URL de redirecionamento (deve ser a mesma cadastrada no app Bling)
# Em desenvolvimento: http://localhost:3000/api/auth/callback
# Em produção: https://seu-dominio.vercel.app/api/auth/callback
BLING_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Tokens (opcional - preenchidos automaticamente após login OAuth)
# Use apenas se quiser pular o fluxo de login na interface
BLING_ACCESS_TOKEN=
BLING_REFRESH_TOKEN=
